{
  "expo": {
    "name": "App",
    "slug": "App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.webp",
    "scheme": "app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digitag.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.digitag.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.webp",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "edgeToEdgeEnabled": true,
    "predictiveBackGestureEnabled": false,
    "extra": {
      "eas": {
        "projectId": "d58be13e-2bc0-499d-9999-f8bfdbd00d9e"
      }
    }
  },
  "web": {
    "output": "static",
    "favicon": "./assets/images/favicon.webp"
  },
  "plugins": [
    "expo-router",
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/splash-icon.webp",
        "imageWidth": 200,
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "backgroundColor": "#000000"
        }
      }
    ],
    "@react-native-firebase/app",
    "@react-native-firebase/auth",
    "@react-native-firebase/messaging",
    "expo-web-browser"
  ],
  "experiments": {
    "typedRoutes": true,
    "reactCompiler": false
  },
  "extra": {
    "router": {},
    "eas": {
      "projectId": "d58be13e-2bc0-499d-9999-f8bfdbd00d9e"
    }
  }
}
