{
  "expo": {
    "name": "digitag",
    "slug": "digitag",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "digitag",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.thedigitag.app",
      "appleTeamId": "CKD6A9LCR6",
      "associatedDomains": [
        "applinks:thedigitag.ai"
      ],
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSCameraUsageDescription": "This app requires camera access to capture photos and videos.",
        "NSMicrophoneUsageDescription": "This app requires microphone access to record audio.",
        "NSPhotoLibraryUsageDescription": "This app requires photo library access to select images.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.592827124863-v1s5kjsu4ci5rgtf6t72shido94j0h44"
            ]
          }
        ],
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      },
      "buildNumber": "4",
      "icon": "./assets/images/icon-ios.png"
    },
    "android": {
      "package": "ai.thedigitag.app",
      "versionCode": 37,
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "thedigitag.ai",
              "pathPrefix": "/profile"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "thedigitag.ai",
              "pathPrefix": "/post"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png"
      },
      "privacyPolicyUrl": "https://thedigitag.ai/privacy-policy",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://thedigitag.ai"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A10",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain"
        }
      ],
      "@react-native-firebase/app",
      [
        "@react-native-firebase/auth",
        {
          "captchaOpenUrlFix": true
        }
      ],
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBMessaging"
            ]
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DigiTag needs your location to share it in chat."
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "teamc-ih",
          "project": "digitag-mobile"
        }
      ],
      "expo-iap",
      "./plugins/withSentryAuthToken"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "origin": "https://thedigitag.ai"
      },
      "eas": {
        "projectId": "af41a154-0e43-4c6a-87e2-e402131d540d"
      }
    },
    "owner": "digitag.teamc"
  }
}
